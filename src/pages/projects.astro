---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title="Projects — Nadeesha Dilruwan"
  description="Selected projects and open-source work by Nadeesha Dilruwan."
>
  <header class="mb-12">
    <p class="font-mono text-sm text-[var(--color-accent)] mb-2">~/projects</p>
    <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight mb-3">Projects</h1>
    <p class="text-[var(--color-muted)]">
      Things I've built — side projects, open-source contributions, and selected work.
    </p>
  </header>

  {
    projects.length === 0 ? (
      <div class="rounded-lg border border-dashed border-[var(--color-border)] bg-[var(--color-surface)]/40 p-12 text-center">
        <p class="font-mono text-sm text-[var(--color-accent)] mb-3">// coming soon</p>
        <p class="text-[var(--color-muted)] mb-2">
          Project entries land here as Markdown files in
          <code class="font-mono text-sm text-[var(--color-text)]">src/content/projects/</code>.
        </p>
        <p class="text-sm text-[var(--color-subtle)]">
          See <code class="font-mono">_example.md.template</code> in that folder for the schema.
        </p>
      </div>
    ) : (
      <ul class="space-y-4">
        {projects.map(({ data }) => (
          <li>
            <article class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6 hover:border-[var(--color-accent)] transition-colors">
              <div class="flex items-start justify-between gap-4 mb-2">
                <h2 class="text-lg font-medium text-[var(--color-text)]">{data.title}</h2>
                <div class="flex items-center gap-3 text-[var(--color-subtle)] shrink-0">
                  {data.repo && (
                    <a
                      href={data.repo}
                      target="_blank"
                      rel="noopener"
                      aria-label="Repository"
                      class="hover:text-[var(--color-accent)]"
                    >
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.58.23 2.75.12 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.07.78 2.16v3.2c0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z" />
                      </svg>
                    </a>
                  )}
                  {data.demo && (
                    <a
                      href={data.demo}
                      target="_blank"
                      rel="noopener"
                      aria-label="Live demo"
                      class="hover:text-[var(--color-accent)]"
                    >
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" y1="14" x2="21" y2="3" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
              <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-4">{data.description}</p>
              {data.tech.length > 0 && (
                <ul class="flex flex-wrap gap-2">
                  {data.tech.map((t) => (
                    <li class="font-mono text-xs px-2 py-1 rounded border border-[var(--color-border)] text-[var(--color-subtle)]">
                      {t}
                    </li>
                  ))}
                </ul>
              )}
            </article>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
